#!/usr/bin/env sh
set -eu

if ! command -v buf >/dev/null 2>&1; then
  echo "buf is required to generate protobuf clients before commit" >&2
  exit 1
fi

if ! command -v protoc-gen-go >/dev/null 2>&1; then
  echo "protoc-gen-go is required to generate protobuf clients before commit" >&2
  exit 1
fi

if ! command -v protoc-gen-go-grpc >/dev/null 2>&1; then
  echo "protoc-gen-go-grpc is required to generate protobuf clients before commit" >&2
  exit 1
fi

make proto

if ! git diff --quiet -- .gen; then
  echo "generated protobuf clients are stale; review and commit .gen changes" >&2
  exit 1
fi
